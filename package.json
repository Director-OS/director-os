{
  "name": "director-os",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered operating system for real estate teams",
  "packageManager": "npm@11.16.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -b tsconfig.json --pretty",
    "lint": "eslint \"{apps,packages}/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:api": "npm run --workspace @director-os/api start",
    "start:web": "npm run --workspace @director-os/web start",
    "clean": "npm run --workspaces --if-present clean && rm -rf .cache"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^22.13.5",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.38.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}